<%= form_with model: [story, chapter], class: "space-y-6" do |f| %>
  <% if chapter.errors.any? %>
    <div class="alert alert-error">
      <h3 class="font-bold"><%= pluralize(chapter.errors.count, t('.error')) %> <%= t '.prohibited' %></h3>
      <ul class="list-disc list-inside mt-2">
        <% chapter.errors.full_messages.each do |message| %>
          <li><%= message %></li>
        <% end %>
      </ul>
    </div>
  <% end %>

  <div>
    <%= f.label :title, t('.title_label'), class: "label" %>
    <%= f.text_field :title, class: "input input-bordered w-full", placeholder: t('.title_placeholder') %>
  </div>

  <div>
    <%= f.label :content, t('.content_label'), class: "label" %>
    <%= f.text_area :content, rows: 20, class: "textarea textarea-bordered w-full font-serif", placeholder: t('.content_placeholder') %>
    <p class="text-sm text-base-content/60 mt-1">
      <span id="word-count">0</span> <%= t '.words' %>
    </p>
  </div>

  <div>
    <%= f.label :position, t('.position_label'), class: "label" %>
    <%= f.number_field :position, class: "input input-bordered w-full", min: 1 %>
  </div>

  <div class="flex space-x-4">
    <%= f.submit t('.submit'), class: "btn btn-primary" %>
    <%= link_to t('.cancel'), chapter.persisted? ? [story, chapter] : story, class: "btn btn-secondary" %>
  </div>
<% end %>

<script>
    document.addEventListener('turbo:load', () => {
        const contentField = document.querySelector('textarea[name="chapter[content]"]');
        const wordCountSpan = document.getElementById('word-count');

        if (contentField && wordCountSpan) {
            const updateWordCount = () => {
                const text = contentField.value.trim();
                const wordCount = text ? text.split(/\s+/).length : 0;
                wordCountSpan.textContent = wordCount;
            };

            contentField.addEventListener('input', updateWordCount);
            updateWordCount();
        }
    });
</script>