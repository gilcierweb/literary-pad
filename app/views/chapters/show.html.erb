<div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8 py-8">
  <!-- Chapter Navigation -->
  <div class="mb-6">
    <%= link_to @story, class: "inline-flex items-center text-primary hover:opacity-80" do %>
      <svg class="w-5 h-5 mr-2" fill="none" stroke="currentColor" viewBox="0 0 24 24">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 19l-7-7 7-7"/>
      </svg>
      <%= t '.back_to' %> <%= @story.title %>
    <% end %>
  </div>

  <!-- Chapter Header -->
  <div class="card bg-base-200 p-8 mb-6">
    <div class="mb-4">
      <span class="text-sm text-base-content/60"><%= t '.chapter' %> <%= @chapter.position %></span>
      <h1 class="text-4xl font-bold text-base-content mt-2"><%= @chapter.title %></h1>
    </div>

    <div class="flex items-center justify-between text-sm text-base-content/70 pb-4 border-b border-base-300">
      <div class="flex items-center space-x-4">
        <%= link_to profile_path(@story.user), class: "flex items-center hover:text-primary" do %>
          <span class="font-semibold"><%= @story.author_name %></span>
        <% end %>
        <span>•</span>
        <span><%= @chapter.published_at&.strftime("%B %d, %Y") %></span>
        <span>•</span>
        <span><%= @chapter.word_count %> <%= t '.words' %></span>
        <span>•</span>
        <span><%= @chapter.reading_time %> <%= t '.min_read' %></span>
      </div>
      <div>
        👁 <%= @chapter.views_count %>
      </div>
    </div>

    <!-- Chapter Content -->
    <div class="prose prose-lg max-w-none mt-8 text-base-content leading-relaxed" style="font-family: var(--font-serif);">
      <%= simple_format(@chapter.content) %>
    </div>

    <!-- Chapter Actions -->
    <% if can? :manage, @chapter %>
      <div class="mt-8 pt-6 border-t border-base-300 flex space-x-4">
        <%= link_to t('.edit'), edit_story_chapter_path(@story, @chapter), class: "btn btn-secondary" %>
        <%= button_to t('.delete'), story_chapter_path(@story, @chapter), method: :delete, data: { turbo_confirm: t('.confirm') }, class: "btn btn-error" %>
      </div>
    <% end %>
  </div>

  <!-- Chapter Navigation -->
  <div class="flex justify-between mb-8">
    <% if @chapter.previous_chapter %>
      <%= link_to story_chapter_path(@story, @chapter.previous_chapter), class: "btn btn-secondary" do %>
        <%= t '.previous' %>
      <% end %>
    <% else %>
      <div></div>
    <% end %>

    <% if @chapter.next_chapter %>
      <%= link_to story_chapter_path(@story, @chapter.next_chapter), class: "btn btn-primary" do %>
        <%= t '.next' %>
      <% end %>
    <% end %>
  </div>

  <!-- Comments -->
  <div class="card bg-base-200 p-6">
    <h2 class="text-2xl font-bold text-base-content mb-4"><%= t '.comments' %></h2>

    <% if user_signed_in? %>
      <%= form_with model: [@story, @chapter, Comment.new], local: false, class: "mb-6" do |f| %>
        <%= f.text_area :content, rows: 3, placeholder: t('.placeholder'), class: "textarea textarea-bordered w-full mb-2" %>
        <%= f.submit t('.post_comment'), class: "btn btn-primary" %>
      <% end %>
    <% end %>

    <div id="comments">
      <%= render @comments %>
    </div>
  </div>
</div>