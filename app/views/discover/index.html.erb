<div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-8">
  <div class="mb-8">
    <h1 class="text-4xl font-bold text-base-content mb-2"><%= t '.title' %></h1>
    <p class="text-base-content/70"><%= t '.subtitle' %></p>
  </div>

  <!-- Search & Filters -->
  <div class="card bg-base-200 p-6 mb-8">
    <%= form_with url: discover_path, method: :get, class: "space-y-4" do |f| %>
      <div class="grid grid-cols-1 md:grid-cols-3 gap-4">
        <div class="md:col-span-2">
          <%= f.text_field :q, value: params[:q], placeholder: t('.search_placeholder'), class: "input input-bordered w-full" %>
        </div>
        <div>
          <%= f.select :sort,
                       options_for_select([[t('.most_recent'), "recent"], [t('.most_popular'), "popular"]], params[:sort]),
                       {},
                       class: "select select-bordered w-full" %>
        </div>
      </div>

      <div>
        <label class="block text-sm font-medium text-base-content mb-2"><%= t '.filter_by_genre' %></label>
        <div class="flex flex-wrap gap-2">
          <% @genres.each do |genre| %>
            <%= link_to discover_path(genre_id: genre.id, q: params[:q], sort: params[:sort]),
                        class: "badge #{params[:genre_id].to_i == genre.id ? 'badge-primary' : 'badge-soft badge-neutral'} cursor-pointer" do %>
              <%= genre.name %>
            <% end %>
          <% end %>
          <% if params[:genre_id].present? %>
            <%= link_to t('.clear_filter'), discover_path(q: params[:q], sort: params[:sort]), class: "badge badge-error badge-soft cursor-pointer" %>
          <% end %>
        </div>
      </div>

      <div class="flex space-x-2">
        <%= f.submit t('.search'), class: "btn btn-primary" %>
        <%= link_to t('.clear_all'), discover_path, class: "btn btn-secondary" %>
      </div>
    <% end %>
  </div>

  <!-- Results -->
  <div class="mb-4">
    <p class="text-base-content/70">
      <% if params[:q].present? || params[:genre_id].present? %>
        <%= t '.showing_results' %>
        <% if params[:q].present? %><%= t '.for' %> "<%= params[:q] %>"<% end %>
        <% if params[:genre_id].present? %>
          <%= t '.in' %> <%= Genre.find(params[:genre_id]).name %>
        <% end %>
      <% else %>
        <%= t '.showing_all' %>
      <% end %>
    </p>
  </div>

  <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 xl:grid-cols-4 gap-6">
    <% @stories.each do |story| %>
      <%= render "stories/card", story: story %>
    <% end %>
  </div>

  <% if @stories.empty? %>
    <div class="text-center py-16">
      <p class="text-base-content/60 text-lg"><%= t '.no_stories' %></p>
      <%= link_to t('.clear_filters'), discover_path, class: "btn btn-primary mt-4" %>
    </div>
  <% end %>

  <div class="mt-8">
    <%== pagy_nav(@pagy) if @pagy.pages > 1 %>
  </div>
</div>