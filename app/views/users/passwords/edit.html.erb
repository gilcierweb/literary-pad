<div>
  <h3 class="text-base-content mb-1.5 text-2xl font-semibold">Change your password</h3>
  <p class="text-base-content/80">Enter your new password below</p>
</div>

<%= form_for(resource, as: resource_name, url: password_path(resource_name), html: { method: :put }) do |f| %>
  <%= render "users/shared/error_messages", resource: resource %>
  <%= f.hidden_field :reset_password_token %>

  <div class="mb-4">
    <%= f.label :password, "New password", class: "label-text" %>
    <% if @minimum_password_length %>
    <em class="text-sm text-base-content/60">(<%= @minimum_password_length %> characters minimum)</em>
    <% end %>
    <%= f.password_field :password, autofocus: true, autocomplete: "new-password", class: "input input-bordered w-full" %>
  </div>

  <div class="mb-6">
    <%= f.label :password_confirmation, "Confirm new password", class: "label-text" %>
    <%= f.password_field :password_confirmation, autocomplete: "new-password", class: "input input-bordered w-full" %>
  </div>

  <div class="mb-4">
    <%= f.submit "Change my password", class: "btn btn-lg btn-primary btn-block" %>
  </div>
<% end %>

<%= render "users/shared/links" %>
