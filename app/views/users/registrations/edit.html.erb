<div>
  <h3 class="text-base-content mb-1.5 text-2xl font-semibold">Edit Profile</h3>
  <p class="text-base-content/80">Update your account information</p>
</div>

<%= form_for(resource, as: resource_name, url: registration_path(resource_name), html: { method: :put }) do |f| %>
  <%= render "users/shared/error_messages", resource: resource %>

  <div class="mb-4">
    <%= f.label :email, class: "label-text" %>
    <%= f.email_field :email, autofocus: true, autocomplete: "email", class: "input input-bordered w-full" %>
  </div>

  <% if devise_mapping.confirmable? && resource.pending_reconfirmation? %>
    <div class="mb-4 text-sm text-base-content/80">Currently waiting confirmation for: <%= resource.unconfirmed_email %></div>
  <% end %>

  <div class="mb-4">
    <%= f.label :password, class: "label-text" %>
    <i class="text-sm text-base-content/60">(leave blank if you don't want to change it)</i>
    <%= f.password_field :password, autocomplete: "new-password", class: "input input-bordered w-full" %>
    <% if @minimum_password_length %>
    <em class="text-sm text-base-content/60"><%= @minimum_password_length %> characters minimum</em>
    <% end %>
  </div>

  <div class="mb-4">
    <%= f.label :password_confirmation, class: "label-text" %>
    <%= f.password_field :password_confirmation, autocomplete: "new-password", class: "input input-bordered w-full" %>
  </div>

  <div class="mb-6">
    <%= f.label :current_password, class: "label-text" %>
    <i class="text-sm text-base-content/60">(we need your current password to confirm your changes)</i>
    <%= f.password_field :current_password, autocomplete: "current-password", class: "input input-bordered w-full" %>
  </div>

  <div class="mb-4">
    <%= f.submit "Update", class: "btn btn-lg btn-primary btn-block" %>
  </div>
<% end %>

<div class="divider"></div>

<div class="mb-4">
  <h3 class="text-base-content mb-2 text-lg font-semibold">Cancel my account</h3>
  <p class="text-base-content/80 mb-4">Unhappy?</p>
  <%= button_to "Cancel my account", registration_path(resource_name), data: { confirm: "Are you sure?", turbo_confirm: "Are you sure?" }, method: :delete, class: "btn btn-error btn-sm" %>
</div>

<div class="text-center">
  <%= link_to "Back", :back, class: "link link-primary" %>
</div>
