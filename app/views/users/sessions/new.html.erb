<div>
  <h3 class="text-base-content mb-1.5 text-2xl font-semibold"><%= t '.title' %></h3>
  <p class="text-base-content/80"><%= t '.subtitle', app_name: t('app.name') %></p>
</div>

<%= form_for(resource, as: resource_name, url: session_path(resource_name)) do |f| %>
  <div class="mb-4">
    <%= f.label :email, class: "label-text" %>
    <%= f.email_field :email, autofocus: true, autocomplete: "email", class: "input input-bordered w-full" %>
  </div>

  <div class="mb-4">
    <%= f.label :password, class: "label-text" %>
    <%= f.password_field :password, autocomplete: "current-password", class: "input input-bordered w-full" %>
  </div>

  <% if devise_mapping.rememberable? %>
    <div class="mb-6 flex items-center justify-between gap-y-2">
      <div class="flex items-center gap-2">
        <%= f.check_box :remember_me, class: "checkbox checkbox-primary checkbox-sm" %>
        <%= f.label :remember_me, t('.remember_me'), class: "label-text text-base-content/80 p-0 text-base" %>
      </div>
      <%= link_to t('.forgot_password'), new_password_path(resource_name), class: "link link-animated link-primary font-normal" %>
    </div>
  <% end %>

  <div class="mb-4">
    <%= f.submit t('.submit'), class: "btn btn-lg btn-primary btn-block" %>
  </div>
<% end %>

<p class="text-base-content/80 mb-4 text-center">
  <%= t '.new_platform' %>
  <%= link_to t('.create_account'), new_registration_path(resource_name), class: "link link-animated link-primary font-normal" %>
</p>

<div class="divider"><%= t '.or' %></div>

<%= render "users/shared/links" %>
