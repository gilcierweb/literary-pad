<div class="max-w-md mx-auto px-4 py-8">
  <h2 class="text-3xl font-bold text-base-content text-center mb-6">Log in</h2>

  <div class="card bg-base-200 p-6">
    <%= form_for(resource, as: resource_name, url: session_path(resource_name)) do |f| %>
      <div class="mb-4">
        <%= f.label :email, class: "label" %>
        <%= f.email_field :email, autofocus: true, autocomplete: "email", class: "input input-bordered w-full" %>
      </div>

      <div class="mb-4">
        <%= f.label :password, class: "label" %>
        <%= f.password_field :password, autocomplete: "current-password", class: "input input-bordered w-full" %>
      </div>

      <% if devise_mapping.rememberable? %>
        <div class="mb-6">
          <label class="label cursor-pointer justify-start gap-2">
            <%= f.check_box :remember_me, class: "checkbox checkbox-primary" %>
            <span class="label-text"><%= f.label :remember_me, class: "label-text" %></span>
          </label>
        </div>
      <% end %>

      <div class="actions">
        <%= f.submit "Log in", class: "btn btn-primary w-full" %>
      </div>
    <% end %>
  </div>

  <div class="text-center mt-4">
    <%= render "users/shared/links" %>
  </div>
</div>
