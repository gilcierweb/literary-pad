<nav class="navbar bg-base-100 shadow-base-300/20 shadow-sm border-b border-base-300">
  <div class="navbar-start">
    <%= link_to root_path, class: "link text-base-content link-neutral text-xl font-bold no-underline" do %>
      📚 LiteraryPad
    <% end %>

    <ul class="menu menu-horizontal gap-2 px-1 hidden md:flex">
      <li><%= link_to "Discover", discover_path, class: "text-base-content hover:text-primary" %></li>
      <li><%= link_to "Stories", stories_path, class: "text-base-content hover:text-primary" %></li>
    </ul>
  </div>

  <div class="navbar-end gap-2">
    <% if user_signed_in? %>
      <%= link_to "Dashboard", dashboard_path, class: "btn btn-ghost btn-sm" %>
      <%= link_to "Write", new_story_path, class: "btn btn-primary btn-sm" %>

      <div class="relative" data-controller="dropdown">
        <button type="button" class="btn btn-ghost btn-sm" data-action="click->dropdown#toggle">
          <%= current_user.profile.display_name %>
          <span class="icon-[tabler--chevron-down] size-4"></span>
        </button>

        <div data-dropdown-target="menu" class="hidden absolute right-0 mt-2 w-48 bg-base-200 rounded-lg shadow-lg py-1 z-10 dropdown-content">
          <%= link_to "My Profile", profile_path(current_user), class: "block px-4 py-2 text-sm text-base-content hover:bg-base-300" %>
          <%= link_to "Settings", edit_profile_path(current_user), class: "block px-4 py-2 text-sm text-base-content hover:bg-base-300" %>
          <div class="divider my-1"></div>
          <%= button_to "Sign Out", destroy_user_session_path, method: :delete, class: "block w-full text-left px-4 py-2 text-sm text-error hover:bg-base-300" %>
        </div>
      </div>
    <% else %>
      <%= link_to "Sign In", new_user_session_path, class: "btn btn-ghost btn-sm" %>
      <%= link_to "Sign Up", new_user_registration_path, class: "btn btn-primary btn-sm" %>
    <% end %>
  </div>
</nav>