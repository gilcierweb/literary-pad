          <button id="user-menu-dropdown" type="button" class="dropdown-toggle btn btn-ghost btn-sm" aria-haspopup="menu" aria-expanded="false" aria-label="User menu">
            <%= current_user.profile.display_name %>
            <span class="icon-[tabler--chevron-down] dropdown-open:rotate-180 size-4"></span>
          </button>
          <ul class="dropdown-menu dropdown-open:opacity-100 hidden min-w-48" role="menu" aria-orientation="vertical" aria-labelledby="user-menu-dropdown">
            <li><%= link_to t('.my_profile'), profile_path(current_user), class: "dropdown-item" %></li>
            <li><%= link_to t('.settings'), edit_profile_path(current_user), class: "dropdown-item" %></li>
            <li><hr class="dropdown-divider"></li>
            <li><%= button_to t('.sign_out'), destroy_user_session_path, method: :delete, class: "dropdown-item text-error" %></li>
          </ul>
        </div>
      </div>
    <% else %>
      <div class="dropdown relative inline-flex md:hidden">
        <button id="mobile-menu-dropdown" type="button" class="dropdown-toggle btn btn-text btn-secondary btn-square" aria-haspopup="menu" aria-expanded="false" aria-label="Mobile menu">
          <span class="icon-[tabler--menu-2] dropdown-open:hidden size-5"></span>
          <span class="icon-[tabler--x] dropdown-open:block hidden size-5"></span>
        </button>
        <ul class="dropdown-menu dropdown-open:opacity-100 hidden min-w-60" role="menu" aria-orientation="vertical" aria-labelledby="mobile-menu-dropdown">
          <li><%= link_to t('.discover'), discover_path, class: "dropdown-item" %></li>
          <li><%= link_to t('.stories'), stories_path, class: "dropdown-item" %></li>
          <li><hr class="dropdown-divider"></li>
          <li><%= link_to t('.sign_in'), new_user_session_path, class: "dropdown-item" %></li>
          <li><%= link_to t('.sign_up'), new_user_registration_path, class: "dropdown-item" %></li>
        </ul>
      </div>
      <div class="hidden md:flex items-center gap-2">
        <%= link_to t('.sign_in'), new_user_session_path, class: "btn btn-ghost btn-sm" %>
        <%= link_to t('.sign_up'), new_user_registration_path, class: "btn btn-primary btn-sm" %>
