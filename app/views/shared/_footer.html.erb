<footer class="bg-base-200 border-t border-base-300 mt-16">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-12">
    <div class="grid grid-cols-1 md:grid-cols-4 gap-8">
      <div>
        <h3 class="text-lg font-bold text-base-content mb-4"><%= t '.title' %></h3>
        <p class="text-base-content/70 text-sm"><%= t '.description' %></p>
      </div>

      <div>
        <h4 class="font-semibold text-base-content mb-4"><%= t '.explore' %></h4>
        <ul class="space-y-2 text-sm">
          <li><%= link_to t('.discover_stories'), discover_path, class: "text-base-content/70 hover:text-primary" %></li>
          <li><%= link_to t('.browse_genres'), discover_path, class: "text-base-content/70 hover:text-primary" %></li>
          <li><%= link_to t('.popular_stories'), stories_path(sort: "popular"), class: "text-base-content/70 hover:text-primary" %></li>
        </ul>
      </div>

      <div>
        <h4 class="font-semibold text-base-content mb-4"><%= t '.create' %></h4>
        <ul class="space-y-2 text-sm">
          <li><%= link_to t('.write_story'), new_story_path, class: "text-base-content/70 hover:text-primary" %></li>
          <li><%= link_to t('.dashboard'), dashboard_path, class: "text-base-content/70 hover:text-primary" %></li>
        </ul>
      </div>

      <div>
        <h4 class="font-semibold text-base-content mb-4"><%= t '.community' %></h4>
        <ul class="space-y-2 text-sm">
          <li><a href="#" class="text-base-content/70 hover:text-primary"><%= t '.guidelines' %></a></li>
          <li><a href="#" class="text-base-content/70 hover:text-primary"><%= t '.support' %></a></li>
          <li><a href="#" class="text-base-content/70 hover:text-primary"><%= t '.about_us' %></a></li>
        </ul>
      </div>
    </div>

    <div class="divider mt-8"></div>
    <div class="text-center text-sm text-base-content/60">
      <p><%= t '.copyright', year: Time.current.year %></p>
    </div>
  </div>
</footer>