<div class="bg-gradient-to-r from-primary to-secondary text-base-content">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-20">
    <div class="text-center">
      <h1 class="text-5xl font-bold mb-6 text-primary-content"><%= t '.hero_title' %></h1>
      <p class="text-xl mb-8 text-primary-content/80"><%= t '.hero_subtitle' %></p>
      <div class="flex justify-center space-x-4">
        <%= link_to t('.start_reading'), discover_path, class: "btn btn-primary" %>
        <%= link_to t('.start_writing'), new_story_path, class: "btn btn-secondary" %>
      </div>
    </div>
  </div>
</div>

<div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-16">
  <!-- Featured Stories -->
  <section class="mb-16">
    <div class="flex justify-between items-center mb-8">
      <h2 class="text-3xl font-bold text-base-content"><%= t '.featured_stories' %></h2>
      <%= link_to t('.view_all'), stories_path, class: "btn btn-ghost btn-sm" %>
    </div>

    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6">
      <% @featured_stories.each do |story| %>
        <%= render "stories/card", story: story %>
      <% end %>
    </div>
  </section>

  <!-- Popular Genres -->
  <section class="mb-16">
    <h2 class="text-3xl font-bold text-base-content mb-8"><%= t '.browse_by_genre' %></h2>
    <div class="grid grid-cols-2 md:grid-cols-4 gap-4">
      <% @popular_genres.each do |genre| %>
        <%= link_to discover_path(genre_id: genre.id), class: "card bg-base-200 hover:bg-base-300 p-6 text-center hover:scale-105 transition transform cursor-pointer" do %>
          <h3 class="font-semibold text-base-content"><%= genre.name %></h3>
        <% end %>
      <% end %>
    </div>
  </section>

  <!-- Recent Stories -->
  <section>
    <div class="flex justify-between items-center mb-8">
      <h2 class="text-3xl font-bold text-base-content"><%= t '.recently_published' %></h2>
      <%= link_to t('.view_all'), stories_path, class: "btn btn-ghost btn-sm" %>
    </div>

    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-6">
      <% @recent_stories.each do |story| %>
        <%= render "stories/card", story: story %>
      <% end %>
    </div>
  </section>
</div>