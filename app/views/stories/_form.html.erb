<%= form_with model: story, class: "space-y-6" do |f| %>
  <% if story.errors.any? %>
    <div class="alert alert-error">
      <h3 class="font-bold"><%= pluralize(story.errors.count, "error") %> prohibited this story from being saved:</h3>
      <ul class="list-disc list-inside mt-2">
        <% story.errors.full_messages.each do |message| %>
          <li><%= message %></li>
        <% end %>
      </ul>
    </div>
  <% end %>

  <div>
    <%= f.label :title, "Story Title", class: "label" %>
    <%= f.text_field :title, class: "input input-bordered w-full", placeholder: "Enter your story title" %>
  </div>

  <div>
    <%= f.label :description, "Description", class: "label" %>
    <%= f.text_area :description, rows: 5, class: "textarea textarea-bordered w-full", placeholder: "Describe your story..." %>
    <p class="text-sm text-base-content/60 mt-1">A compelling description helps readers discover your story</p>
  </div>

  <div>
    <%= f.label :genre_ids, "Genres", class: "label" %>
    <%= f.collection_check_boxes :genre_ids, Genre.all, :id, :name do |b| %>
      <div class="inline-flex items-center mr-4 mb-2">
        <%= b.check_box class: "checkbox checkbox-primary" %>
        <%= b.label class: "ml-2 text-sm text-base-content" %>
      </div>
    <% end %>
  </div>

  <div>
    <%= f.label :cover_image, "Cover Image URL (optional)", class: "label" %>
    <%= f.text_field :cover_image, class: "input input-bordered w-full", placeholder: "https://example.com/cover.jpg" %>
  </div>

  <div>
    <%= f.label :status, "Status", class: "label" %>
    <%= f.select :status, Story.statuses.keys.map { |k| [k.titleize, k] }, {}, class: "select select-bordered w-full" %>
  </div>

  <div class="flex space-x-4">
    <%= f.submit class: "btn btn-primary" %>
    <%= link_to "Cancel", story.persisted? ? story : stories_path, class: "btn btn-secondary" %>
  </div>
<% end %>