<%= form_with model: story, class: "space-y-6" do |f| %>
  <% if story.errors.any? %>
    <div class="alert alert-error">
      <h3 class="font-bold"><%= pluralize(story.errors.count, t('.error')) %> <%= t '.prohibited' %></h3>
      <ul class="list-disc list-inside mt-2">
        <% story.errors.full_messages.each do |message| %>
          <li><%= message %></li>
        <% end %>
      </ul>
    </div>
  <% end %>

  <div>
    <%= f.label :title, t('.title_label'), class: "label" %>
    <%= f.text_field :title, class: "input input-bordered w-full", placeholder: t('.title_placeholder') %>
  </div>

  <div>
    <%= f.label :description, t('.description_label'), class: "label" %>
    <%= f.rich_text_area :description, rows: 5, class: "textarea textarea-bordered w-full", placeholder: t('.description_placeholder') %>
    <p class="text-sm text-base-content/60 mt-1"><%= t '.description_help' %></p>
  </div>

  <div>
    <%= f.label :genre_ids, t('.genres_label'), class: "label" %>
    <%= f.collection_check_boxes :genre_ids, Genre.all, :id, :name do |b| %>
      <div class="inline-flex items-center mr-4 mb-2">
        <%= b.check_box class: "checkbox checkbox-primary" %>
        <%= b.label class: "ml-2 text-sm text-base-content" %>
      </div>
    <% end %>
  </div>

  <div>
    <%= f.label :cover_image, t('.cover_image_label'), class: "label" %>
    <%= f.text_field :cover_image, class: "input input-bordered w-full", placeholder: t('.cover_image_placeholder') %>
  </div>

  <div>
    <%= f.label :status, t('.status_label'), class: "label" %>
    <%= f.select :status, Story.statuses.keys.map { |k| [k.titleize, k] }, {}, class: "select select-bordered w-full" %>
  </div>

  <div class="flex space-x-4">
    <%= f.submit t('.submit'), class: "btn btn-primary" %>
    <%= link_to t('.cancel'), story.persisted? ? story : stories_path, class: "btn btn-secondary" %>
  </div>
<% end %>