<%= link_to story, class: "card bg-base-200 hover:bg-base-300 overflow-hidden group cursor-pointer" do %>
  <div class="aspect-[3/4] bg-gradient-to-br from-primary to-secondary relative">
    <% if story.cover_image.present? %>
      <%= image_tag story.cover_image, class: "w-full h-full object-cover" %>
    <% else %>
      <div class="flex items-center justify-center h-full text-primary-content text-4xl font-bold">
        <%= story.title.first %>
      </div>
    <% end %>
    <div class="absolute top-2 right-2 badge badge-neutral">
      <%= story.status.titleize %>
    </div>
  </div>

  <div class="card-body p-4">
    <h3 class="card-title text-base-content mb-2 line-clamp-2 group-hover:text-primary transition">
      <%= story.title %>
    </h3>

    <p class="text-sm text-base-content/70 mb-3">
      by <%= story.author_name %>
    </p>

    <p class="text-sm text-base-content/60 line-clamp-2 mb-3">
      <%= story.description %>
    </p>

    <div class="flex items-center justify-between text-xs text-base-content/50">
      <div class="flex space-x-3">
        <span>👁 <%= story.views_count %></span>
        <span>❤️ <%= story.likes_count %></span>
        <span>💬 <%= story.comments_count %></span>
      </div>
      <span><%= story.chapters_count %> chapters</span>
    </div>

    <% if story.genres.any? %>
      <div class="flex flex-wrap gap-2 mt-3">
        <% story.genres.first(3).each do |genre| %>
          <span class="badge badge-soft badge-primary">
            <%= genre.name %>
          </span>
        <% end %>
      </div>
    <% end %>
  </div>
<% end %>
