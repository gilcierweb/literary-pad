<div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8 py-8">
  <div class="mb-8">
    <h1 class="text-4xl font-bold text-base-content mb-2"><%= t '.title' %></h1>
    <p class="text-base-content/70"><%= t '.subtitle' %></p>
  </div>

  <div class="card bg-base-200 p-8">
    <%= form_with model: @profile, url: profile_path(current_user), method: :patch, class: "space-y-6" do |f| %>
      <% if @profile.errors.any? %>
        <div class="alert alert-error">
          <h3 class="font-bold"><%= pluralize(@profile.errors.count, t('.error')) %> <%= t '.prohibited' %></h3>
          <ul class="list-disc list-inside mt-2">
            <% @profile.errors.full_messages.each do |message| %>
              <li><%= message %></li>
            <% end %>
          </ul>
        </div>
      <% end %>

      <div>
        <%= f.label :pen_name, t('.pen_name'), class: "label" %>
        <%= f.text_field :pen_name, class: "input input-bordered w-full", placeholder: t('.pen_name_placeholder') %>
      </div>

      <div>
        <%= f.label :bio, t('.bio'), class: "label" %>
        <%= f.text_area :bio, rows: 4, class: "textarea textarea-bordered w-full", placeholder: t('.bio_placeholder') %>
        <p class="text-sm text-base-content/60 mt-1"><%= t '.bio_max' %></p>
      </div>

      <div>
        <%= f.label :location, t('.location'), class: "label" %>
        <%= f.text_field :location, class: "input input-bordered w-full", placeholder: t('.location_placeholder') %>
      </div>

      <div>
        <%= f.label :website, t('.website'), class: "label" %>
        <%= f.url_field :website, class: "input input-bordered w-full", placeholder: t('.website_placeholder') %>
      </div>

      <div>
        <%= f.label :avatar, t('.avatar'), class: "label" %>
        <%= f.text_field :avatar, class: "input input-bordered w-full", placeholder: t('.avatar_placeholder') %>
      </div>

      <div class="flex space-x-4">
        <%= f.submit t('.save_changes'), class: "btn btn-primary" %>
        <%= link_to t('.cancel'), profile_path(current_user), class: "btn btn-secondary" %>
      </div>
    <% end %>
  </div>
</div>