<div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8 py-8">
  <div class="mb-8">
    <h1 class="text-4xl font-bold text-base-content mb-2">Edit Profile</h1>
    <p class="text-base-content/70">Update your profile information</p>
  </div>

  <div class="card bg-base-200 p-8">
    <%= form_with model: @profile, url: profile_path(current_user), method: :patch, class: "space-y-6" do |f| %>
      <% if @profile.errors.any? %>
        <div class="alert alert-error">
          <h3 class="font-bold"><%= pluralize(@profile.errors.count, "error") %> prohibited this profile from being saved:</h3>
          <ul class="list-disc list-inside mt-2">
            <% @profile.errors.full_messages.each do |message| %>
              <li><%= message %></li>
            <% end %>
          </ul>
        </div>
      <% end %>

      <div>
        <%= f.label :pen_name, "Pen Name", class: "label" %>
        <%= f.text_field :pen_name, class: "input input-bordered w-full", placeholder: "Your author name" %>
      </div>

      <div>
        <%= f.label :bio, "Bio", class: "label" %>
        <%= f.text_area :bio, rows: 4, class: "textarea textarea-bordered w-full", placeholder: "Tell readers about yourself..." %>
        <p class="text-sm text-base-content/60 mt-1">Maximum 500 characters</p>
      </div>

      <div>
        <%= f.label :location, "Location", class: "label" %>
        <%= f.text_field :location, class: "input input-bordered w-full", placeholder: "City, Country" %>
      </div>

      <div>
        <%= f.label :website, "Website", class: "label" %>
        <%= f.url_field :website, class: "input input-bordered w-full", placeholder: "https://yourwebsite.com" %>
      </div>

      <div>
        <%= f.label :avatar, "Avatar URL", class: "label" %>
        <%= f.text_field :avatar, class: "input input-bordered w-full", placeholder: "https://example.com/avatar.jpg" %>
      </div>

      <div class="flex space-x-4">
        <%= f.submit "Save Changes", class: "btn btn-primary" %>
        <%= link_to "Cancel", profile_path(current_user), class: "btn btn-secondary" %>
      </div>
    <% end %>
  </div>
</div>