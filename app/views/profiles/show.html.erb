<div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-8">
  <div class="card bg-base-200 p-8 mb-8">
    <div class="flex items-start justify-between">
      <div class="flex items-center space-x-6">
        <div class="avatar">
          <div class="w-24 h-24 rounded-full bg-gradient-to-br from-primary to-secondary flex items-center justify-center text-primary-content text-3xl font-bold">
            <%= @user.profile.display_name.first.upcase %>
          </div>
        </div>

        <div>
          <h1 class="text-3xl font-bold text-base-content mb-2"><%= @user.profile.display_name %></h1>
          <% if @user.profile.bio.present? %>
            <p class="text-base-content/70 mb-3"><%= @user.profile.bio %></p>
          <% end %>

          <div class="flex items-center space-x-6 text-sm text-base-content/70">
            <div>
              <span class="font-semibold text-base-content"><%= @user.stories.count %></span>
              <%= t '.stories' %>
            </div>
            <div>
              <span class="font-semibold text-base-content"><%= @user.followers.count %></span>
              <%= t '.followers' %>
            </div>
            <div>
              <span class="font-semibold text-base-content"><%= @user.following.count %></span>
              <%= t '.following' %>
            </div>
          </div>
        </div>
      </div>

      <div class="flex space-x-2">
        <% if user_signed_in? %>
          <% if current_user == @user %>
            <%= link_to t('.edit_profile'), edit_profile_path(@user), class: "btn btn-secondary" %>
          <% else %>
            <% if current_user.following?(@user) %>
              <%= button_to t('.unfollow'), user_follow_path(@user, current_user.active_follows.find_by(followed: @user)), method: :delete, id: "follow_button_User_#{@user.id}", class: "btn btn-secondary" %>
            <% else %>
              <%= button_to t('.follow'), user_follows_path(@user), method: :post, id: "follow_button_User_#{@user.id}", class: "btn btn-primary" %>
            <% end %>
          <% end %>
        <% end %>
      </div>
    </div>
  </div>

  <!-- Stories -->
  <div class="mb-8">
    <h2 class="text-2xl font-bold text-base-content mb-6"><%= t '.stories_by' %> <%= @user.profile.display_name %></h2>

    <% if @stories.any? %>
      <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 xl:grid-cols-4 gap-6">
        <% @stories.each do |story| %>
          <%= render "stories/card", story: story %>
        <% end %>
      </div>
    <% else %>
      <div class="text-center py-12 card bg-base-200">
        <p class="text-base-content/60"><%= t '.no_stories' %></p>
      </div>
    <% end %>
  </div>
</div>