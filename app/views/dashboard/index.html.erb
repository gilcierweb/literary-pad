<div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-8">
  <div class="mb-8">
    <h1 class="text-4xl font-bold text-base-content mb-2"><%= t '.title' %></h1>
    <p class="text-base-content/70"><%= t '.subtitle' %></p>
  </div>

  <!-- Stats Cards -->
  <div class="grid grid-cols-1 md:grid-cols-4 gap-6 mb-8">
    <div class="card bg-base-200 p-6">
      <div class="text-3xl font-bold text-primary mb-2"><%= @stats[:stories_count] %></div>
      <div class="text-base-content/70"><%= t '.stories' %></div>
    </div>
    <div class="card bg-base-200 p-6">
      <div class="text-3xl font-bold text-primary mb-2"><%= @stats[:total_views] %></div>
      <div class="text-base-content/70"><%= t '.total_views' %></div>
    </div>
    <div class="card bg-base-200 p-6">
      <div class="text-3xl font-bold text-primary mb-2"><%= @stats[:total_likes] %></div>
      <div class="text-base-content/70"><%= t '.total_likes' %></div>
    </div>
    <div class="card bg-base-200 p-6">
      <div class="text-3xl font-bold text-primary mb-2"><%= @stats[:followers_count] %></div>
      <div class="text-base-content/70"><%= t '.followers' %></div>
    </div>
  </div>

  <div class="grid grid-cols-1 lg:grid-cols-3 gap-8">
    <!-- My Stories -->
    <div class="lg:col-span-2">
      <div class="card bg-base-200 p-6">
        <div class="flex justify-between items-center mb-6">
          <h2 class="text-2xl font-bold text-base-content"><%= t '.my_stories' %></h2>
          <%= link_to t('.create_new_story'), new_story_path, class: "btn btn-primary" %>
        </div>

        <% if @my_stories.any? %>
          <div class="space-y-4">
            <% @my_stories.each do |story| %>
              <div class="border border-base-300 rounded-lg p-4 hover:border-primary transition">
                <div class="flex justify-between items-start">
                  <div class="flex-1">
                    <%= link_to story, class: "block group" do %>
                      <h3 class="font-bold text-lg text-base-content group-hover:text-primary mb-1">
                        <%= story.title %>
                      </h3>
                    <% end %>
                    <p class="text-sm text-base-content/70 mb-2"><%= truncate(story.description, length: 100) %></p>

                    <div class="flex items-center space-x-4 text-xs text-base-content/60">
                      <span class="badge badge-soft"><%= story.status.titleize %></span>
                      <span>👁 <%= story.views_count %></span>
                      <span>❤️ <%= story.likes_count %></span>
                      <span>💬 <%= story.comments_count %></span>
                      <span><%= story.chapters_count %> <%= t '.chapters' %></span>
                    </div>
                  </div>

                  <div class="ml-4 flex space-x-2">
                    <%= link_to t('.edit'), edit_story_path(story), class: "text-sm text-primary hover:opacity-80" %>
                    <%= link_to new_story_chapter_path(story), class: "text-sm text-success hover:opacity-80" do %>
                      <%= t '.add_chapter' %>
                    <% end %>
                  </div>
                </div>
              </div>
            <% end %>
          </div>
        <% else %>
          <div class="text-center py-12">
            <p class="text-base-content/60 mb-4"><%= t '.no_stories' %></p>
            <%= link_to t('.create_first_story'), new_story_path, class: "btn btn-primary" %>
          </div>
        <% end %>
      </div>
    </div>

    <!-- Sidebar -->
    <div class="space-y-6">
      <!-- Reading History -->
      <div class="card bg-base-200 p-6">
        <h3 class="text-xl font-bold text-base-content mb-4"><%= t '.continue_reading' %></h3>
        <% if @reading_history.any? %>
          <div class="space-y-3">
            <% @reading_history.first(5).each do |reading| %>
              <%= link_to story_chapter_path(reading.chapter.story, reading.chapter), class: "block p-3 bg-base-100 rounded-lg hover:bg-base-300 transition" do %>
                <h4 class="font-semibold text-sm text-base-content line-clamp-1">
                  <%= reading.chapter.story.title %>
                </h4>
                <p class="text-xs text-base-content/70 mt-1">
                  <%= t '.chapter' %> <%= reading.chapter.position %>: <%= reading.chapter.title %>
                </p>
                <div class="mt-2 bg-base-300 rounded-full h-1.5">
                  <div class="bg-primary h-1.5 rounded-full" style="width: <%= reading.progress %>%"></div>
                </div>
              <% end %>
            <% end %>
          </div>
        <% else %>
          <p class="text-base-content/60 text-sm"><%= t '.no_reading_history' %></p>
        <% end %>
      </div>

      <!-- Favorites -->
      <div class="card bg-base-200 p-6">
        <h3 class="text-xl font-bold text-base-content mb-4"><%= t '.my_favorites' %></h3>
        <% if @favorites.any? %>
          <div class="space-y-3">
            <% @favorites.each do |story| %>
              <%= link_to story, class: "block p-3 bg-base-100 rounded-lg hover:bg-base-300 transition" do %>
                <h4 class="font-semibold text-sm text-base-content line-clamp-2">
                  <%= story.title %>
                </h4>
                <p class="text-xs text-base-content/70 mt-1">
                  by <%= story.author_name %>
                </p>
              <% end %>
            <% end %>
          </div>
        <% else %>
          <p class="text-base-content/60 text-sm"><%= t '.no_favorites' %></p>
        <% end %>
      </div>
    </div>
  </div>
</div>
